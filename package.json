  "repository": {
    "type": "git",
    "url": "git+https://github.com/Revex-Agency/fema-nfhl-mcp.git"
  },
  "homepage": "https://github.com/Revex-Agency/fema-nfhl-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
